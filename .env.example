# Anthropic API key for the LLM mapper
ANTHROPIC_API_KEY=

# Postgres connection string
DATABASE_URL=postgresql+psycopg://fermdocs:fermdocs@localhost:5432/fermdocs

# Where the file store puts uploaded source files
FERMDOCS_DATA_DIR=./data

# Optional: override the bundled golden schema YAML
# FERMDOCS_SCHEMA_PATH=/path/to/golden_schema.yaml

# Default behavior summary:
#   - Mapper:             ON  (always; pick provider below)
#   - Rule-based normalizer: ON (always; deterministic, no LLM cost)
#   - LLM unit normalizer:   ON  (degrades gracefully if API key missing)
#   - Tier 1 narrative capture: ON (always; data preservation, no LLM cost)
#   - Tier 2 narrative LLM extraction: ON (graceful degrade on missing key)
# To go fully offline, use: --fake-mapper (forces all LLM tiers off).

# Mapper provider: gemini | anthropic | fake
FERMDOCS_MAPPER_PROVIDER=gemini

# Gemini config (default provider)
GEMINI_API_KEY=
FERMDOCS_GEMINI_MODEL=gemini-3-flash

# Anthropic config (used only if FERMDOCS_MAPPER_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=
# FERMDOCS_MAPPER_MODEL=claude-haiku-4-5-20251001

# Unit normalizer (rule-based always on; LLM fallback ON by default).
# Set to false to disable the LLM tier (rule-based stays on either way).
FERMDOCS_USE_LLM_NORMALIZER=true
# Optional: separate provider for normalizer (falls back to FERMDOCS_MAPPER_PROVIDER)
# FERMDOCS_NORMALIZER_PROVIDER=anthropic

# Narrative extraction ON by default. Tier 1 capture (paragraphs in residual JSONB)
# is unconditional regardless of this flag. Cost is ~10-50x mapper because it uses
# Sonnet for prose reasoning. Set to false to disable Tier 2 only.
FERMDOCS_EXTRACT_NARRATIVE=true
# Optional: separate provider/model for narrative extractor.
# FERMDOCS_NARRATIVE_PROVIDER=anthropic
# FERMDOCS_NARRATIVE_MODEL=claude-sonnet-4-6
