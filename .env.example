# Anthropic API key for the LLM mapper
ANTHROPIC_API_KEY=

# Postgres connection string
DATABASE_URL=postgresql+psycopg://fermdocs:fermdocs@localhost:5432/fermdocs

# Where the file store puts uploaded source files
FERMDOCS_DATA_DIR=./data

# Optional: override the bundled golden schema YAML
# FERMDOCS_SCHEMA_PATH=/path/to/golden_schema.yaml

# Mapper provider: anthropic | gemini | fake
FERMDOCS_MAPPER_PROVIDER=anthropic

# Anthropic config
FERMDOCS_MAPPER_MODEL=claude-haiku-4-5-20251001

# Gemini config (only needed if FERMDOCS_MAPPER_PROVIDER=gemini)
GEMINI_API_KEY=
FERMDOCS_GEMINI_MODEL=gemini-2.5-flash
